# Copy to .env for local dev (gitignored). On Railway, set these as service variables.

# Required — the OpenAI key the agent uses. Lives ONLY server-side, never in /site.
OPENAI_API_KEY=sk-...

# Optional — model for the dossier agent (default: gpt-4.1-mini)
# DOSSIER_MODEL=gpt-4.1-mini

# Optional — comma-separated CORS allowlist (browser fetch origins).
# Defaults to spp3.steg.eth.link/.limo + localhost:3000/3001
# ALLOWED_ORIGINS=https://spp3.steg.eth.link,http://localhost:3001
